<html>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    {{ content_for_header }}
    {{ 'b-reset.css' | asset_url | stylesheet_tag }}
    {{ 'b-utils.css' | asset_url | stylesheet_tag }}
    {% render 'fonts' %}

    <link rel="stylesheet" href="https://unpkg.com/lenis@1.3.23/dist/lenis.css">

    <script src="https://cdn.jsdelivr.net/npm/gsap@3.15/dist/gsap.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.15/dist/ScrollTrigger.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.15/dist/SplitText.min.js" defer></script>
    <script src="https://unpkg.com/lenis@1.3.23/dist/lenis.min.js" defer></script>
    <script src="{{ 'j-global.js' | asset_url }}" defer></script>
  </head>
  <body>
    <div id="_" style="opacity: 0; visibility: hidden;">
      {% section 'header' %}
      {% section 'cart-drawer' %}
      {{ content_for_layout }}
      {% section 'footer' %}
    </div>
  </body>
</html>
