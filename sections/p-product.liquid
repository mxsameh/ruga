{{ 's-p-product.css' | asset_url | stylesheet_tag }}
{{ 's-product-card.css' | asset_url | stylesheet_tag }}
<script src="{{ 'j-product.js' | asset_url }}" defer></script>
<script src="{{ 'j-accordion.js' | asset_url }}" defer></script>

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  if current_variant.compare_at_price > current_variant.price
    assign compare_at_price = current_variant.compare_at_price
  endif

  assign bgc = product.metafields.custom.background_color
%}

<div class="p" style="--bgc: {{ bgc }};">
  <div class="product">
    {% comment %}
      IMAGES
    {% endcomment %}

    {% render 'product-gallery' %}

    {% comment %}
      PRODUCT INFO
    {% endcomment %}
    <div class="product_info_">
      <div class="product_info">
        <h1 class="product_title">
          <span>RUGA</span>
          {{ product.title | upcase }}
        </h1>
        <div class="product_desc">
          <p>
            {{ product.description | strip_html }}
          </p>
        </div>

        {% render 'product-form' %}
      </div>
      {% if product.title contains 'Cooler' %}
        <div class="product_data">
          {% if product.metafields.custom.capacity %}
            {% render 'accordion',
              heading: 'Capacity: 5 Turtles',
              content: 'RUGA Turtle Scale (Capacity System)
          A simple way to measure capacity across RUGA products:
          1 Turtle ≈ 8 x 330L cans',
              default: 'Regular size'
            %}
          {% endif %}
          {% render 'accordion',
            heading: 'Dimensions',
            content: 'Outside Dimensions: 622 × 432 mm
            Inside Dimensions: 285 × 495 mm
            Capacity: 5 turtles',
            default: 'Regular size'
          %}
        </div>
      {% endif %}
    </div>
  </div>

  {% render 'complementary-products' %}

  {% render 'recommended-products' %}

  <footer class="f">
    <img src="{{ 'im-footer.png' | asset_url  }}" width="auto" height="auto" alt="logo">
  </footer>
</div>

<script>
  const product = {{ product | json }};
</script>

{% schema %}
{
  "name": "product",
  "settings": []
}
{% endschema %}
