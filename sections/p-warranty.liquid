{{ 's-p-warranty.css' | asset_url | stylesheet_tag }}
<script src="{{ 'a-warranty.js' | asset_url }}" defer></script>

<div id="p">
  <section class="s-he">
    <h1 class="title">
      <div>
        <span>BUILT TO </span>
        <span>PERFORM.</span>
      </div>
      <div>
        <span>DESIGNED</span>
        <span>TO LAST.</span>
      </div>
    </h1>
    <figure>
      <picture>
        <source srcset="{{'rup.webp' | asset_url}}" media="(min-width: 770px)">
        <img src="{{ 'im-ban-m.png' | asset_url  }}" width="auto" height="auto" alt="logo">
      </picture>
    </figure>
  </section>
  <section class="s-war">
    <p>Your Ruga icebox comes with a 3-year warranty. Complete your registration below to activate your coverage.</p>
    <form>
      <fieldset>
        <input type="text" id="name" name="name" placeholder="Name" required>
      </fieldset>
      <fieldset>
        <input type="text" id="phone" name="phone" required placeholder="Phone (optional)">
      </fieldset>
      <fieldset>
        <input type="email" id="email" name="email" required placeholder="Email">
      </fieldset>
      <fieldset>
        <input type="text" id="code" name="code" required placeholder="Code">
      </fieldset>
      <button type="submit">SUBMIT</button>
    </form>
  </section>
</div>
