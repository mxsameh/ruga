{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign available = current_variant.available
%}

{% form 'product', product, class: 'pf' %}
  <input type="hidden" id="variant-id" name="id" value="{{ current_variant.id }}">
  {% comment %}
    Options
  {% endcomment %}

  {% unless product.has_only_default_variant %}
    {% for option in product.options_with_values %}
      {% render 'product-option', option: option %}
    {% endfor %}
  {% endunless %}

  {% comment %}
    Add to Cart
  {% endcomment %}
  <div class="product_atc_">
    <div class="product_price">
      <div class="current-price">
        <span>{{ current_variant.price | money_without_currency | remove: '.00' }}</span>
        {{ shop.currency }}
      </div>
      <div
        class="compare-price {%unless compare_at_price %}d-n{% endunless %}"
      >
        <span>
          {{ current_variant.compare_at_price | money_without_currency | remove: '.00' }}
        </span>
        {{ shop.currency }}
      </div>
    </div>

    <div class="product_atc">
      {% if available %}
        <button
          type="submit"
        >
          Add to cart
        </button>
      {% else %}
        <button
          type="submit"
          disabled
          class="disabled"
        >
          Sold Out
        </button>
      {% endif %}
    </div>
  </div>
{% endform %}
